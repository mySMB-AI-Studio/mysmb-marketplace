{
  "mcpServers": {
    "xero": {
      "type": "stdio",
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/server/dist/index.js"],
      "env": {
        "XERO_CLIENT_ID": "${XERO_CLIENT_ID}",
        "XERO_CLIENT_SECRET": "${XERO_CLIENT_SECRET}",
        "XERO_REDIRECT_URI": "${XERO_REDIRECT_URI}",
        "XERO_TENANT_ID": "${XERO_TENANT_ID}"
      }
    }
  }
}
